model user_notification {
  id                                     String    @id @db.Uuid
  created_at                             DateTime? @db.Timestamp(6)
  updated_at                             DateTime? @db.Timestamp(6)
  is_deleted                             Boolean
  user_id                                String?   @db.Uuid
  is_read                                Boolean?
  trader_id                              String?   @db.Uuid
  setup_id                               String?   @db.Uuid
  message                                String?   @db.VarChar
  type                                   Int       @db.SmallInt
  message_id                             String?   @db.VarChar
  updated_column                         String?   @db.VarChar
  column_value                           String?   @db.VarChar
  setup                                  setup?    @relation(fields: [setup_id], references: [id], onDelete: Restrict)
  user_user_notification_trader_idTouser user?     @relation("user_notification_trader_idTouser", fields: [trader_id], references: [id], onDelete: Restrict)
  user_user_notification_user_idTouser   user?     @relation("user_notification_user_idTouser", fields: [user_id], references: [id], onDelete: Restrict)

  @@index([created_at], map: "ix_user_notification_created_at")
  @@index([is_deleted], map: "ix_user_notification_is_deleted")
}

model user_session {
  user_id            String    @db.Uuid
  device_id          String?   @db.VarChar
  registration_token String?   @db.VarChar
  is_active          Boolean   @default(true)
  revoked_at         DateTime? @db.Timestamp(6)
  last_seen_at       DateTime? @db.Timestamp(6)
  os_name            String?   @db.VarChar
  os_version         String?   @db.VarChar
  app_version        String?   @db.VarChar
  ip_address         String?   @db.VarChar
  id                 String    @id @db.Uuid
  created_at         DateTime? @db.Timestamp(6)
  updated_at         DateTime? @db.Timestamp(6)
  is_deleted         Boolean
  user               user      @relation(fields: [user_id], references: [id])

  @@index([created_at], map: "ix_user_session_created_at")
  @@index([device_id], map: "ix_user_session_device_id")
  @@index([is_deleted], map: "ix_user_session_is_deleted")
  @@index([registration_token], map: "ix_user_session_registration_token")
  @@index([user_id], map: "ix_user_session_user_id")
}

model user_subscription {
  id                                     String                    @id @db.Uuid
  created_at                             DateTime?                 @db.Timestamp(6)
  updated_at                             DateTime?                 @db.Timestamp(6)
  is_deleted                             Boolean
  user_id                                String                    @db.Uuid
  product_id                             String?                   @db.Uuid
  market                                 String                    @db.VarChar
  transaction_id                         String                    @db.VarChar
  raw_data                               String
  data                                   String
  start_date                             DateTime                  @db.Timestamp(6)
  expire_date                            DateTime                  @db.Timestamp(6)
  is_expired                             Boolean
  is_cancelled                           Boolean
  is_trial                               Boolean
  is_payment_received                    Boolean?
  trader_id                              String?                   @db.Uuid
  auto_renew_status                      Boolean                   @default(false)
  auto_renew_product_code                String?                   @db.VarChar
  price                                  Float?
  currency                               String?                   @db.VarChar
  subscription_pool                      subscription_pool[]
  trader_referral_earning                trader_referral_earning[]
  product                                product?                  @relation(fields: [product_id], references: [id], onDelete: Restrict)
  user_user_subscription_trader_idTouser user?                     @relation("user_subscription_trader_idTouser", fields: [trader_id], references: [id], onDelete: Restrict)
  user_user_subscription_user_idTouser   user                      @relation("user_subscription_user_idTouser", fields: [user_id], references: [id])

  @@unique([market, transaction_id])
  @@index([created_at], map: "ix_user_subscription_created_at")
  @@index([expire_date], map: "ix_user_subscription_expire_date")
  @@index([is_cancelled], map: "ix_user_subscription_is_cancelled")
  @@index([is_deleted], map: "ix_user_subscription_is_deleted")
  @@index([is_expired], map: "ix_user_subscription_is_expired")
  @@index([start_date], map: "ix_user_subscription_start_date")
  @@index([transaction_id], map: "ix_user_subscription_transaction_id")
}

model voucher {
  code                       String               @unique(map: "ix_voucher_code") @db.VarChar(64)
  name                       String?              @db.VarChar(128)
  type                       String               @db.VarChar(16)
  start_at                   DateTime?            @db.Timestamp(6)
  end_at                     DateTime?            @db.Timestamp(6)
  is_active                  Boolean
  max_uses                   Int?
  max_uses_per_user          Int?
  usage_count                Int
  membership_duration_days   Int?
  membership_duration_months Int?
  discount_type              String?              @db.VarChar(16)
  discount_value             Float?
  credits_amount             Float?
  utm_source                 String?              @db.VarChar(128)
  utm_medium                 String?              @db.VarChar(128)
  utm_campaign               String?              @db.VarChar(128)
  utm_term                   String?              @db.VarChar(128)
  utm_content                String?              @db.VarChar(128)
  created_by                 String?              @db.Uuid
  meta_data                  Json?
  id                         String               @id @db.Uuid
  created_at                 DateTime?            @db.Timestamp(6)
  updated_at                 DateTime?            @db.Timestamp(6)
  is_deleted                 Boolean
  new_users_only             Boolean              @default(false)
  new_users_days             Int?
  user                       user?                @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  voucher_redemption         voucher_redemption[]

  @@index([is_active, start_at, end_at], map: "ix_voucher_active_dates")
  @@index([created_at], map: "ix_voucher_created_at")
  @@index([end_at], map: "ix_voucher_end_at")
  @@index([is_active], map: "ix_voucher_is_active")
  @@index([is_deleted], map: "ix_voucher_is_deleted")
  @@index([start_at], map: "ix_voucher_start_at")
  @@index([type], map: "ix_voucher_type")
}

model voucher_redemption {
  voucher_id       String    @db.Uuid
  user_id          String    @db.Uuid
  redeemed_at      DateTime  @db.Timestamp(6)
  status           String    @db.VarChar(16)
  reason           String?
  credit_tx_id     String?   @db.Uuid
  subscription_id  String?   @db.Uuid
  credits_added    Float?
  original_price   Float?
  final_price      Float?
  discount_amount  Float?
  discount_percent Float?
  meta_data        Json?
  id               String    @id @db.Uuid
  created_at       DateTime? @db.Timestamp(6)
  updated_at       DateTime? @db.Timestamp(6)
  is_deleted       Boolean
  user             user      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  voucher          voucher   @relation(fields: [voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "ix_voucher_redemption_created_at")
  @@index([is_deleted], map: "ix_voucher_redemption_is_deleted")
  @@index([redeemed_at], map: "ix_voucher_redemption_redeemed_at")
  @@index([status], map: "ix_voucher_redemption_status")
  @@index([user_id], map: "ix_voucher_redemption_user_id")
  @@index([voucher_id], map: "ix_voucher_redemption_voucher_id")
}

model watch_list {
  id         String    @id @db.Uuid
  created_at DateTime? @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  is_deleted Boolean
  user_id    String?   @db.Uuid
  setup_id   String?   @db.Uuid
  setup      setup?    @relation(fields: [setup_id], references: [id], onDelete: Restrict)
  user       user?     @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@unique([user_id, setup_id])
  @@index([created_at], map: "ix_watch_list_created_at")
  @@index([is_deleted], map: "ix_watch_list_is_deleted")
}

model webhook {
  id                   String             @id @db.Uuid
  created_at           DateTime?          @db.Timestamp(6)
  updated_at           DateTime?          @db.Timestamp(6)
  is_deleted           Boolean            @default(false)
  user_id              String             @db.Uuid
  url                  String             @db.VarChar(2048)
  secret               String             @db.VarChar(256)
  events               Json               @default("[]")
  scope                webhook_scope_enum @default(own)
  is_active            Boolean            @default(true)
  description          String?            @db.VarChar(512)
  consecutive_failures Int                @default(0)
  last_triggered_at    DateTime?          @db.Timestamptz(6)
  user                 user               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  webhook_delivery     webhook_delivery[]

  @@index([created_at], map: "ix_webhook_created_at")
  @@index([is_active], map: "ix_webhook_is_active")
  @@index([is_deleted], map: "ix_webhook_is_deleted")
  @@index([user_id, is_active], map: "ix_webhook_user_active")
  @@index([user_id], map: "ix_webhook_user_id")
}

model webhook_delivery {
  id            String    @id @db.Uuid
  created_at    DateTime? @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)
  is_deleted    Boolean   @default(false)
  webhook_id    String    @db.Uuid
  event_type    String    @db.VarChar(64)
  payload       Json
  status_code   Int?
  response_body String?
  success       Boolean   @default(false)
  attempt       Int       @default(1)
  next_retry_at DateTime? @db.Timestamptz(6)
  delivered_at  DateTime? @db.Timestamptz(6)
  error_message String?   @db.VarChar(512)
  webhook       webhook   @relation(fields: [webhook_id], references: [id], onDelete: Cascade)

  @@index([created_at], map: "ix_webhook_delivery_created_at")
  @@index([event_type], map: "ix_webhook_delivery_event_type")
  @@index([is_deleted], map: "ix_webhook_delivery_is_deleted")
  @@index([next_retry_at], map: "ix_webhook_delivery_next_retry_at")
  @@index([next_retry_at, success], map: "ix_webhook_delivery_retry")
  @@index([webhook_id], map: "ix_webhook_delivery_webhook_id")
}

enum categories_type {
  spot
  futures
}

enum durations_type {
  shortterm
  midterm
  longterm
}

enum order_types_type {
  market
  limit
  stop
}

enum positions_type {
  long
  short
}

enum statuses_type {
  incoming
  active
  cancelled
  stopped
  success
  closed
}

enum webhook_scope_enum {
  own
  subscribed_shops
  followed_traders
}
