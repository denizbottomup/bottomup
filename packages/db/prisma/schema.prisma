  @@unique([trader_id, copy_trade_market])
  @@index([is_active, copy_trade_market], map: "ix_active_market")
  @@index([created_at], map: "ix_affiliate_trader_credentials_created_at")
  @@index([is_active], map: "ix_affiliate_trader_credentials_is_active")
  @@index([is_deleted], map: "ix_affiliate_trader_credentials_is_deleted")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model api_key {
  user_id      String    @db.Uuid
  name         String    @db.VarChar(128)
  key_prefix   String    @db.VarChar(8)
  key_hash     String    @unique @db.VarChar(64)
  scopes       Json
  allowed_ips  Json?
  expires_at   DateTime  @db.Timestamptz(6)
  last_used_at DateTime? @db.Timestamptz(6)
  is_active    Boolean   @default(true)
  id           String    @id @db.Uuid
  created_at   DateTime? @db.Timestamp(6)
  updated_at   DateTime? @db.Timestamp(6)
  is_deleted   Boolean   @default(false)
  user         user      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at], map: "ix_api_key_created_at")
  @@index([is_active], map: "ix_api_key_is_active")
  @@index([is_deleted], map: "ix_api_key_is_deleted")
  @@index([key_prefix], map: "ix_api_key_key_prefix")
  @@index([key_prefix, key_hash], map: "ix_api_key_prefix_hash")
  @@index([user_id, is_active], map: "ix_api_key_user_active")
  @@index([user_id], map: "ix_api_key_user_id")
}

model app_store_product_price {
