generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model omer_premiums {
  email              String? @unique(map: "table_name_pk") @db.VarChar
  is_active          Boolean @default(true)
  is_valid           Boolean @default(true)
  transaction_number Int     @default(dbgenerated("nextval('_omer_premiums_transaction_number_seq'::regclass)"))

  @@map("_omer_premiums")
  @@ignore
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ad_audit_logs {
  id          Int       @id @default(autoincrement())
  admin_id    String    @db.Uuid
  action      String    @db.VarChar(30)
  target_type String    @db.VarChar(20)
  target_id   Int
  payload     Json      @default("{}")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  user        user      @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([admin_id, created_at], map: "ix_audit_admin_id")
  @@index([target_type, target_id], map: "ix_audit_target")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ad_transactions {
  id            Int        @id @default(autoincrement())
  wallet_id     Int
  campaign_id   Int?
  type          String     @db.VarChar(30)
  amount        Decimal    @db.Decimal(12, 2)
  balance_after Decimal    @db.Decimal(12, 2)
  note          String?
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  campaigns     campaigns? @relation(fields: [campaign_id], references: [id], onUpdate: NoAction)
  ad_wallets    ad_wallets @relation(fields: [wallet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([wallet_id, created_at], map: "ix_ad_transactions_wallet")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ad_wallets {
  id              Int               @id @default(autoincrement())
  trader_id       String            @unique @db.Uuid
  balance         Decimal           @default(0) @db.Decimal(12, 2)
  reserved        Decimal           @default(0) @db.Decimal(12, 2)
  updated_at      DateTime?         @default(now()) @db.Timestamptz(6)
  ad_transactions ad_transactions[]
  user            user              @relation(fields: [trader_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ads {
  id           String    @id @db.Uuid
  created_at   DateTime? @db.Timestamp(6)
  updated_at   DateTime? @db.Timestamp(6)
  is_deleted   Boolean
  ads_id       String    @db.VarChar
  ads_group_id String    @db.VarChar
  image        String?   @db.VarChar
  video        String?   @db.VarChar
  content      String?   @db.VarChar
  title        String?   @db.VarChar
  url          String?   @db.VarChar
  lang         String    @default("en") @db.VarChar
  start_date   DateTime  @db.Timestamp(6)
  end_date     DateTime  @db.Timestamp(6)
  pages        String?   @db.VarChar
  campaign     String?   @db.VarChar
  company      String?   @db.VarChar
  sort_no      Int?      @default(0)

  @@index([ads_group_id], map: "ix_ads_ads_group_id")
  @@index([ads_id], map: "ix_ads_ads_id")
  @@index([created_at], map: "ix_ads_created_at")
  @@index([end_date], map: "ix_ads_end_date")
  @@index([is_deleted], map: "ix_ads_is_deleted")
  @@index([lang], map: "ix_ads_lang")
  @@index([start_date], map: "ix_ads_start_date")
}

model affiliate_trader_credentials {
  trader_id         String    @db.Uuid
  is_active         Boolean
  is_demo           Boolean
