{
  "name": "bottomup",
  "version": "3.0.0-mvp",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:pull": "pnpm --filter @bottomup/db db:pull",
    "db:generate": "pnpm --filter @bottomup/db db:generate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5"
  },
  "engines": {
    "node": ">=22"
  }
}
