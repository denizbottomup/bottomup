# ─── Shared ──────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Postgres ──────────────────────────────────────────────────────────
# Railway-managed Postgres mirror that services read from. Workers'
# replicator copies rows into it every MIRROR_INTERVAL_MS from
# bottomup-backend's replication API (see REPLICATION_API_URL below) —
# ask the backend team for a local Postgres or point this at your own.
DATABASE_URL=postgresql://user:PASSWORD@localhost:5432/app?schema=public
# Workers-only: source of the mirror. bottomup-backend prod's Postgres is
# firewalled with no direct-connection path from Railway (no static
# outbound IPv4 to allowlist), so the replicator pulls over HTTPS from
# bottomup-backend's /internal/replication router instead of a DB DSN.
# Leave both unset locally to run workers without the replicator.
# REPLICATION_API_URL=https://api.bottomup.app/internal/replication
# REPLICATION_API_KEY=ask-backend-team-for-REPLICATION_SERVICE_API_KEY

# ─── Redis (Railway plugin) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-openssl-rand-base64-32
JWT_REFRESH_SECRET=change-me-openssl-rand-base64-32
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=86400

# ─── Firebase Admin ──────────────────────────────────────────────────
# Option A: path to service account JSON (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/bottomup-fb-sa.json
# Option B: inline JSON (Railway — paste full JSON as single line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=bottomup-1cb62

# ─── API ─────────────────────────────────────────────────────────────
API_PORT=8000
API_CORS_ORIGINS=*

# ─── WS Gateway ──────────────────────────────────────────────────────
WS_PORT=8001

# ─── Workers ─────────────────────────────────────────────────────────
WORKERS_CONCURRENCY=5

# ─── CoinGlass (market intel proxy) ──────────────────────────────────
# Get from https://coinglass.com/pricing — header CG-API-KEY.
# Optional: without it, MarketIntelService falls back to alternative.me +
# CoinGecko + Binance public endpoints.
COINGLASS_API_KEY=

# ─── OKX Broker API (copy-trade) ─────────────────────────────────────
# Used server-side to validate user pairings, read balances, and route
# copy-trade orders. Per-user keys are stored encrypted in a future
# table; the keys below are the house/test account.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# Set to 1 to point at OKX demo trading environment.
OKX_SIMULATED=0

# ─── Google Tag Manager (web) ────────────────────────────────────────
# Set the container ID (e.g. GTM-XXXX) on the Railway web service env.
# Leave empty locally so dev doesn't spam GTM.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXX

